FROM python:3.11-slim

WORKDIR /app

COPY app/frontend/requirements.txt /app/app/frontend/requirements.txt
RUN pip install --no-cache-dir -r /app/app/frontend/requirements.txt

COPY app /app/app

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

EXPOSE 8501

CMD ["streamlit", "run", "app/frontend/streamlit_app.py", "--server.port=8501", "--server.address=0.0.0.0"]
